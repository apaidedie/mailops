# Flask 配置
# 必须设置！使用以下命令生成：python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=your-secret-key-here

# 登录密码（默认：admin123，首次启动后会自动哈希存储）
# 生产环境建议在部署前直接设置为强密码（至少 8 位）
LOGIN_PASSWORD=admin123

# 是否允许在“系统设置”页面修改登录密码（演示站点建议设为 false）
ALLOW_LOGIN_PASSWORD_CHANGE=true

# 应用配置
PORT=5000
HOST=0.0.0.0
FLASK_ENV=production

# 运行日志：text 适合本地阅读，json 为容器/ELK/Loki 输出逐行 JSON
LOG_FORMAT=text
# 可选：DEBUG、INFO、WARNING、ERROR、CRITICAL；默认 INFO
LOG_LEVEL=INFO
# 旧版性能日志开关仍兼容：未显式设置 LOG_LEVEL 时，true 等价于 DEBUG
# PERF_LOGGING=false

# 是否自动启动后台调度器（定时刷新/心跳）。生产建议 true。
SCHEDULER_AUTOSTART=true

# 数据库路径
DATABASE_PATH=data/outlook_accounts.db

# 临时邮箱 Provider 选择配置
# 可选值：legacy_bridge、mail_tm、duckmail、tempmail_lol、emailnator、cloudflare_temp_mail，留空则使用设置页保存值
# TEMP_MAIL_PROVIDER=mail_tm
# 外部项目不传 provider 领取邮箱时的默认来源；auto 或留空表示自动领取
# EXTERNAL_POOL_DEFAULT_PROVIDER=auto
# 当前实例启用的邮箱来源白名单；留空表示全部启用，支持逗号或换行分隔
# ACTIVE_MAILBOX_PROVIDERS=duckmail,mail_tm,imap
# 可选：用 JSON/TOML 文件声明 provider 选择；环境变量仍优先于该文件
# OUTLOOK_EMAIL_PROVIDER_CONFIG_FILE=.runtime/providers.json

# 外部 API 浏览器 CORS：普通网页来源必须精确列入白名单，支持逗号或换行分隔
# EXTERNAL_API_CORS_ORIGINS=https://console.example.com,http://localhost:3000
# 默认保留 Chrome/Edge 扩展访问；设为 false 可关闭扩展来源
EXTERNAL_API_CORS_ALLOW_CHROME_EXTENSION=true
# 兼容临时邮箱桥接服务根地址；沿用 GPTMAIL_* 变量名以兼容旧部署，不要填 /zh/api 文档页
GPTMAIL_BASE_URL=https://mail.chatgpt.org.uk
# 兼容临时邮箱桥接 API Key；新部署也可优先使用 mail_tm/duckmail/tempmail_lol/emailnator/CF/plugin provider
GPTMAIL_API_KEY=

# 公开临时邮箱 Provider（按 TEMP_MAIL_PROVIDER、ACTIVE_MAILBOX_PROVIDERS 或外部 API provider 选择使用）
# MAILTM_API_BASE=https://api.mail.tm
# DUCKMAIL_API_BASE=https://api.duckmail.sbs
# DUCKMAIL_BEARER_TOKEN=
# TEMPMAIL_LOL_API_KEY=
# TEMP_MAIL_LOL_API_KEY=
# EMAILNATOR_API_KEY=
# EMAILNATOR_EMAIL_TYPES=["public_gmail_plus"]
# CF_WORKER_BASE_URL=
# CF_WORKER_ADMIN_KEY=

# OAuth Token 工具（可选，不填使用默认值）
# OAUTH_TOOL_ENABLED=true
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=
# OAUTH_REDIRECT_URI=http://localhost:5000/token-tool/callback
# OAUTH_SCOPE=offline_access https://outlook.office.com/IMAP.AccessAsUser.All
# 如需 Graph 可改为 offline_access https://graph.microsoft.com/.default（可选扩展）
# OAUTH_TENANT=consumers

# --- 一键更新（可选；配合 docker-compose.yml 中的 Watchtower 使用） ---
# Watchtower HTTP API 地址（默认 http://watchtower:8080，docker-compose 内网互联无需改动）
# WATCHTOWER_API_URL=http://watchtower:8080

# 一键更新鉴权 Token（可留空：留空时与 docker-compose.yml 内置默认值一致，可直接工作）
# 生产环境建议设为随机强密码：python -c "import secrets; print(secrets.token_hex(32))"
# 注意：若填写此处，docker-compose.yml 中 watchtower 服务会自动同步读取同一变量
WATCHTOWER_HTTP_API_TOKEN=

# Docker API 自更新（可选，高级功能）
# ⚠️ 警告：启用后容器可通过 Docker API 控制宿主机其他容器，存在安全风险
# 需同时取消 docker-compose.yml 中 docker.sock 挂载的注释
# DOCKER_SELF_UPDATE_ALLOW=false
